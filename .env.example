# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mindatlas

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# Encryption
ENCRYPTION_MASTER_KEY=your-32-byte-hex-encryption-key

# Third-party API credentials (OpenAI, Twilio, Stripe, Notion) are now
# managed via the Admin Console and stored encrypted in the database.
# See: Admin Console → Platform Credentials
